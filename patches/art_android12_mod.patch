+      LOG(INFO) << "[CLASS_LOAD] DefineClass: " << descriptor 
+                << " from " << dex_file.GetLocation();
+    }
+  }
   ScopedDefiningClass sdc(self);
   StackHandleScope<3> hs(self);
   metrics::AutoTimer timer{GetMetrics()->ClassLoadingTotalTime()};
